{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      ".git/**",
      "**/node_modules/**",
      "firebase-debug.log",
      "package-lock.json",
      "package.json",
      "server.js"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/shops.html"
      }
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/shops.html",
        "type": 302
      }
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/service-worker.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/manifest.json",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/manifest+json"
          }
        ]
      }
    ]
  }
}
